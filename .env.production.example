# Production Environment Variables
# DO NOT commit actual values to git

# API Gateway (Production)
NEXT_PUBLIC_API_URL=https://api.shelfbidder.com/prod/

# Cognito (Production)
NEXT_PUBLIC_USER_POOL_ID=us-east-1_PROD_POOL_ID
NEXT_PUBLIC_USER_POOL_CLIENT_ID=PROD_CLIENT_ID
NEXT_PUBLIC_AWS_REGION=us-east-1

# S3 (Production)
NEXT_PUBLIC_PHOTO_BUCKET_NAME=shelf-bidder-photos-prod
AWS_ACCOUNT_ID=PRODUCTION_ACCOUNT_ID

# AWS Credentials (Server-side only - use IAM roles in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB Tables (Production)
DYNAMODB_SHOPKEEPERS_TABLE=ShelfBidder-Shopkeepers-Prod
DYNAMODB_SHELF_SPACES_TABLE=ShelfBidder-ShelfSpaces-Prod
DYNAMODB_AUCTIONS_TABLE=ShelfBidder-Auctions-Prod
DYNAMODB_TASKS_TABLE=ShelfBidder-Tasks-Prod
DYNAMODB_TRANSACTIONS_TABLE=ShelfBidder-Transactions-Prod

# Step Functions
STEP_FUNCTIONS_STATE_MACHINE_ARN=arn:aws:states:us-east-1:ACCOUNT:stateMachine:ShelfBidder-Workflow-Prod

# Monitoring & Logging
SENTRY_DSN=
CLOUDWATCH_LOG_GROUP=/aws/shelfbidder/prod

# Feature Flags
ENABLE_VOICE_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_OFFLINE_MODE=true
