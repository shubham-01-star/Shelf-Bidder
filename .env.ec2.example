# ============================================================
# EC2 Docker Production Environment
# Copy to .env.ec2 on the EC2 host before running docker-compose.prod.yml
# ============================================================

# ---------- Public App Identity ----------
DOMAIN_NAME=app.example.com
LETSENCRYPT_EMAIL=ops@example.com
NEXT_PUBLIC_APP_URL=https://app.example.com
NEXT_PUBLIC_API_URL=https://app.example.com/api
NGINX_TEMPLATE_PATH=./infrastructure/nginx/default.https.conf.template

# ---------- Next.js / Node ----------
NODE_ENV=production
PORT=3000

# ---------- PostgreSQL ----------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=shelfbidder
DB_USER=postgres
DB_PASSWORD=change_this_postgres_password
DB_SSL=false
DATABASE_URL=postgresql://postgres:change_this_postgres_password@postgres:5432/shelfbidder

# ---------- Auth ----------
AUTH_JWT_SECRET=replace_with_a_long_random_access_secret
AUTH_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
CRON_SECRET=replace_with_a_long_random_cron_secret

# ---------- AWS Runtime (use EC2 IAM Role, not static keys) ----------
AWS_REGION=ap-south-1
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
# Fill these from `cd infrastructure && ./scripts/export-config.sh ShelfBidderStack`
PHOTO_BUCKET_NAME=
S3_BUCKET_PHOTOS=
S3_BACKUP_URI=
CONNECT_INSTANCE_ID=
CONNECT_CONTACT_FLOW_ID=
CONNECT_SOURCE_PHONE_NUMBER=
RESEND_API_KEY=
SENDER_EMAIL=noreply@example.com

# ---------- Public AWS / Browser Config ----------
NEXT_PUBLIC_AWS_REGION=ap-south-1
NEXT_PUBLIC_PHOTO_BUCKET=
NEXT_PUBLIC_PHOTO_BUCKET_NAME=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ---------- Optional Flags ----------
ENABLE_VOICE_NOTIFICATIONS=true
USE_MOCK_DATA=false
