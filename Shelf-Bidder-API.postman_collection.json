      "name": "1. Authentication",
      "item": [
        {
          "name": "Signup - Shopkeeper Registration",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    console.log('Signup successful! Check console for OTP code.');",
                  "    const response = pm.response.json();",
                  "    if (response.otpInConsole) {",
                  "        console.log('OTP is logged in server console');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"password\": \"Test@1234\",\n  \"name\": \"Ramesh Kumar\",\n  \"email\": \"ramesh@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Register a new shopkeeper. OTP will be logged in server console and sent via email."
          },
          "response": []
        },
        {
          "name": "Signin - Password Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    ",
                  "    // Save auth tokens",
                  "    if (response.accessToken) {",
                  "        pm.collectionVariables.set('auth_token', response.accessToken);",
                  "        console.log('✅ Access token saved');",
                  "    }",
                  "    if (response.refreshToken) {",
                  "        pm.collectionVariables.set('refresh_token', response.refreshToken);",
                  "    }",
                  "    ",
                  "    // Extract shopkeeper ID from ID token (has more user info)",
                  "    const tokenToUse = response.idToken || response.accessToken;",
                  "    ",
                  "    if (tokenToUse) {",
                  "        try {",
                  "            const parts = tokenToUse.split('.');",
                  "            if (parts.length >= 2) {",
                  "                // Decode base64url payload",
                  "                const base64 = parts[1].replace(/-/g, '+').replace(/_/g, '/');",
                  "                const padded = base64 + '=='.slice(0, (4 - (base64.length % 4)) % 4);",
                  "                const decoded = JSON.parse(atob(padded));",
                  "                ",
                  "                console.log('\\n========================================');",
                  "                console.log('🎉 LOGIN SUCCESSFUL');",
                  "                console.log('========================================');",
                  "                ",
                  "                if (decoded.sub) {",
                  "                    pm.collectionVariables.set('shopkeeper_id', decoded.sub);",
                  "                    console.log('🆔 Shopkeeper ID:', decoded.sub);",
                  "                }",
                  "                if (decoded.name) {",
                  "                    console.log('👤 Name:', decoded.name);",
                  "                }",
                  "                if (decoded.phone_number) {",
                  "                    console.log('📱 Phone:', decoded.phone_number);",
                  "                }",
                  "                if (decoded.email) {",
                  "                    console.log('📧 Email:', decoded.email);",
                  "                }",
                  "                ",
                  "                console.log('========================================\\n');",
                  "            }",
                  "        } catch (e) {",
                  "            console.error('❌ Failed to decode token:', e);",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signin",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "signin"]
            },
            "description": "Login with phone number and password. Returns JWT token."
          },
          "response": []
        },
        {
          "name": "Verify OTP (After Signup)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    console.log('Phone number verified! Now you can signin.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"{{phone_number}}\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/verify",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "verify"]
            },
            "description": "Verify OTP code after signup. Use code from server console or 123456 for testing."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh"]
            },
