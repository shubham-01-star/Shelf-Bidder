# Local development template
# Copy this file to `.env.local`

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api
USE_MOCK_DATA=false
CRON_SECRET=dev-cron-secret
AUTH_JWT_SECRET=dev-access-secret-change-me
AUTH_REFRESH_SECRET=dev-refresh-secret-change-me

# ---------- PostgreSQL ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shelfbidder
DB_USER=postgres
DB_PASSWORD=postgres_dev_password
DB_SSL=false
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000
DATABASE_URL=postgresql://postgres:postgres_dev_password@localhost:5432/shelfbidder

# ---------- Optional AWS features ----------
# Use `aws configure` or shell environment variables for local credentials.
AWS_REGION=ap-south-1
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
PHOTO_BUCKET_NAME=
S3_BUCKET_PHOTOS=
NEXT_PUBLIC_AWS_REGION=ap-south-1
NEXT_PUBLIC_PHOTO_BUCKET=
NEXT_PUBLIC_PHOTO_BUCKET_NAME=
CONNECT_INSTANCE_ID=
CONNECT_CONTACT_FLOW_ID=
CONNECT_SOURCE_PHONE_NUMBER=
RESEND_API_KEY=
SENDER_EMAIL=
