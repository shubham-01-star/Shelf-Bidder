    "@aws-sdk/client-dynamodb": "^3.998.0",
    "@aws-sdk/client-s3": "^3.998.0",
    "@aws-sdk/client-sfn": "^3.1000.0",
    "@aws-sdk/lib-dynamodb": "^3.998.0",
    "@aws-sdk/s3-request-presigner": "^3.998.0",
    "@tailwindcss/postcss": "^4.2.1",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-pwa": "^5.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "swr": "^2.4.1",
